# ── Model A: the agentic build pipeline ──────────────────────────────────────
# Optional. If set (and FAKE_BUILD is off), the A build runs a real autonomous
# Claude Code session via @anthropic-ai/claude-agent-sdk inside the sandbox.
# Billed to the API account; no interactive login.
ANTHROPIC_API_KEY=

# Zero-cost pipeline mode (plan §12). With this set, the worker skips the agent
# and hosted sandbox and writes a canned multi-file dist — exercises the seal
# gate, bundle store, serving, iframe, SSE, and publishing for $0. Recommended
# for local dev / demo. Leave unset (and provide ANTHROPIC_API_KEY) for real builds.
SINGLETAKE_FAKE_BUILD=1

# Build model + caps (provenance is recorded per-post).
SINGLETAKE_GEN_MODEL=claude-sonnet-4-6
SINGLETAKE_MOD_MODEL=claude-haiku-4-5
SINGLETAKE_MAX_TURNS=60
SINGLETAKE_BUILD_TIMEOUT_MS=1500000

# Sandbox provider (plan §4): local (dev only) | vercel | e2b.
SINGLETAKE_SANDBOX=local

# Seal-gate budgets (plan §5.7). Defaults shown.
# SINGLETAKE_BUNDLE_MAX_BYTES=31457280
# SINGLETAKE_BUNDLE_MAX_FILES=1500
# SINGLETAKE_BUNDLE_MAX_FILE_BYTES=10485760

# Production only: artifact origin for the runtime CSP frame-ancestors (plan
# §7.1). When artifacts are served from a separate usercontent origin, point
# this at the APP origin, e.g. https://singletake.gg. Defaults to 'self' (local).
# SINGLETAKE_APP_ORIGIN='self'

# SQLite location and artifact store. Defaults are fine for local dev.
SINGLETAKE_DB=./data/singletake.db
SINGLETAKE_ARTIFACTS=./data/artifacts

# Session signing secret (HMAC). Set a long random string in any real deploy.
SINGLETAKE_SESSION_SECRET=

# Google OAuth (the "continue with google" button). Create a Web-application
# OAuth client at https://console.cloud.google.com → APIs & Services → Credentials.
# Register this exact redirect URI on the client:
#   http://localhost:3000/api/auth/google/callback
# If these are unset, the Google button shows a "not configured" notice and the
# magic-link path still works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
