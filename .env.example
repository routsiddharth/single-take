# Optional. If set, generation calls the real Anthropic API.
# If unset, single take uses the built-in stub generator (still produces real,
# self-contained HTML artifacts so the full loop works offline).
ANTHROPIC_API_KEY=

# Generation model (provenance is recorded per-post). Defaults below.
SINGLETAKE_GEN_MODEL=claude-sonnet-4-6
SINGLETAKE_MOD_MODEL=claude-haiku-4-5

# SQLite location and artifact store. Defaults are fine for local dev.
SINGLETAKE_DB=./data/singletake.db
SINGLETAKE_ARTIFACTS=./data/artifacts

# Session signing secret (HMAC). Set a long random string in any real deploy.
SINGLETAKE_SESSION_SECRET=

# Google OAuth (the "continue with google" button). Create a Web-application
# OAuth client at https://console.cloud.google.com → APIs & Services → Credentials.
# Register this exact redirect URI on the client:
#   http://localhost:3000/api/auth/google/callback
# If these are unset, the Google button shows a "not configured" notice and the
# magic-link path still works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
